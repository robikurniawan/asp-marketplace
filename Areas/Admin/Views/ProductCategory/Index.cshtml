@model ProductCategoryIndexViewModel
@{
    ViewData["Title"] = "Kategori Produk";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0">Kategori Produk</h4>
    <a asp-action="Create" class="btn btn-primary btn-sm">+ Tambah Kategori</a>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body pb-0">
        <form method="get" class="row g-2 mb-3">
            <div class="col-auto">
                <input type="text" name="search" value="@Model.Search" class="form-control form-control-sm" placeholder="Cari nama kategori..." />
            </div>
            <div class="col-auto">
                <button type="submit" class="btn btn-outline-secondary btn-sm">Cari</button>
                @if (!string.IsNullOrEmpty(Model.Search))
                {
                    <a asp-action="Index" class="btn btn-link btn-sm">Reset</a>
                }
            </div>
        </form>
    </div>

    <table class="table table-hover mb-0">
        <thead class="table-light">
            <tr>
                <th>Nama</th>
                <th>Deskripsi</th>
                <th>Status</th>
                <th>Dibuat</th>
                <th class="text-end">Aksi</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Items)
            {
                <tr>
                    <td class="fw-medium">@item.Name</td>
                    <td class="text-muted">@(item.Description ?? "-")</td>
                    <td>
                        @if (item.IsActive)
                        {
                            <span class="badge bg-success-subtle text-success">Aktif</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary-subtle text-secondary">Nonaktif</span>
                        }
                    </td>
                    <td class="text-muted small">@item.CreatedAt.ToString("dd MMM yyyy")</td>
                    <td class="text-end">
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-primary btn-sm">Edit</a>
                        <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline"
                              onsubmit="return confirm('Hapus kategori @item.Name?')">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-outline-danger btn-sm">Hapus</button>
                        </form>
                    </td>
                </tr>
            }
            @if (!Model.Items.Any())
            {
                <tr>
                    <td colspan="5" class="text-center text-muted py-4">Belum ada kategori.</td>
                </tr>
            }
        </tbody>
    </table>

    @if (Model.TotalPages > 1)
    {
        <div class="card-footer d-flex justify-content-center">
            <nav>
                <ul class="pagination pagination-sm mb-0">
                    @for (int i = 1; i <= Model.TotalPages; i++)
                    {
                        <li class="page-item @(i == Model.Page ? "active" : "")">
                            <a class="page-link" asp-action="Index" asp-route-page="@i" asp-route-search="@Model.Search">@i</a>
                        </li>
                    }
                </ul>
            </nav>
        </div>
    }
</div>
