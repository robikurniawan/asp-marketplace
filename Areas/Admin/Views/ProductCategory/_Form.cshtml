@model ProductCategoryFormViewModel

<div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

<div class="mb-3">
    <label asp-for="Name" class="form-label">Nama Kategori <span class="text-danger">*</span></label>
    <input asp-for="Name" class="form-control" placeholder="Contoh: Elektronik" />
    <span asp-validation-for="Name" class="text-danger small"></span>
</div>

<div class="mb-3">
    <label asp-for="Description" class="form-label">Deskripsi</label>
    <textarea asp-for="Description" class="form-control" rows="3" placeholder="Deskripsi singkat kategori..."></textarea>
    <span asp-validation-for="Description" class="text-danger small"></span>
</div>

<div class="mb-4 form-check form-switch">
    <input asp-for="IsActive" class="form-check-input" role="switch" />
    <label asp-for="IsActive" class="form-check-label">Aktif</label>
</div>
